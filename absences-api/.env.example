# ─────────────────────────────────────────────────────────────────────────
# absences-api — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer le fichier .env dans le dépôt Git.
# ─────────────────────────────────────────────────────────────────────────

# Profil Spring actif : dev | recette | prod
SPRING_PROFILES_ACTIVE=dev

# ── Base de données PostgreSQL ────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://<DB_HOST>:<DB_PORT>/<DB_NAME>
DB_USER=<db_username>
DB_PASS=<db_password>

# ── Keycloak ──────────────────────────────────────────────────────────────
KEYCLOAK_JWKS_URI=https://<KEYCLOAK_HOST>/realms/<REALM>/protocol/openid-connect/certs
KEYCLOAK_ADMIN_API_BASE_URL=https://<KEYCLOAK_HOST>/admin/realms/<REALM>
KEYCLOAK_ADMIN_CLIENT_ID=<admin_client_id>
KEYCLOAK_ADMIN_CLIENT_SECRET=<admin_client_secret>

# ── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET=justificatifs
